QWidget {
    background-color: {{ colors.background.app }};
    color: {{ colors.text.primary }};
    font-family: "{{ typography.FONT_FAMILY }}";
    font-size: {{ typography.BODY_MD }}px;
}

QWidget#CentralWidget {
    background-color: {{ colors.background.app }};
}

QStackedWidget#ContentArea {
    background-color: {{ colors.background.app }};
    padding: {{ spacing.XL }}px;
}

*:focus {
    outline: none;
}

QScrollBar:vertical {
    width: 8px;
    background: transparent;
    margin: {{ spacing.XS }}px 0 {{ spacing.XS }}px 0;
}

QScrollBar::handle:vertical {
    background: {{ colors.background.scroll_bar }};
    border-radius: {{ spacing.XS }}px;
    min-height: 24px;
}

QScrollBar::handle:vertical:hover {
    background: {{ colors.background.scroll_bar_hover }};
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
}

QScrollBar:horizontal {
    height: 8px;
    background: transparent;
    margin: 0 {{ spacing.XS }}px 0 {{ spacing.XS }}px;
}

QScrollBar::handle:horizontal {
    background: {{ colors.background.scroll_bar }};
    border-radius: {{ spacing.XS }}px;
    min-width: 24px;
}

QScrollBar::handle:horizontal:hover {
    background: {{ colors.background.scroll_bar_hover }};
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal {
    width: 0px;
}

QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
}

QWidget#NotionFormWidget {
    background-color: {{ colors.background.item }};
    border: 1px solid {{ colors.border.default }};
    border-radius: {{ radius.XXL }}px;
}

QWidget#NotionFormWidget QLabel {
    background: transparent;
    border: none;
    color: {{ colors.text.primary }};
    font-size: {{ typography.BODY_MD }}px;
    font-weight: {{ typography.MEDIUM }};
}

QWidget#NotionFormHeader {
    background: transparent;
    padding: {{ spacing.SM }}px {{ spacing.MD }}px;
}