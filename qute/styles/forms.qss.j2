QLineEdit#FormLineEdit,
QComboBox#FormComboBox,
QTextEdit#FormTextEdit {
    background-color: #F0F4F9;
    border: 1px solid #E3E8EF;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 14px;
    color: #1F2A37;
}

QLineEdit#FormLineEdit:focus,
QComboBox#FormComboBox:focus,
QTextEdit#FormTextEdit:focus {
    border: 1px solid #4C6EF5;
    background-color: #FFFFFF;
}

QScrollArea#FormScrollArea {
    border: 1px solid #E3E8EF;
    border-radius: 8px;
    background-color: #F0F4F9;
    padding: 4px;
}

QWidget#TagsContainer {
    background: transparent;
}

QCheckBox#FormCheckBox {
    background: transparent;
    spacing: 6px;
    font-size: 13px;
    color: #1F2A37;
}

QCheckBox#FormCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid #E3E8EF;
    background: #FFFFFF;
}

QCheckBox#FormCheckBox::indicator:checked {
    background-color: #4C6EF5;
    border: 1px solid #4C6EF5;
}