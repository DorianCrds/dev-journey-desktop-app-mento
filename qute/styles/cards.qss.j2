QWidget#CardNotion, QWidget#CardCategory, QWidget#CardTag, QWidget#CardStat {
    background-color: #FFFFFF;
    border: 1px solid #E3E8EF;
    border-radius: 10px;
    padding: 16px;
}

QWidget#CardNotion:hover, QWidget#CardCategory:hover, QWidget#CardTag:hover {
    background-color: #F9FBFE;
}

QWidget#CardCategory[selected="true"] {
    background-color: #F5F8FF;
    border: 1px solid #5B8DEF;
}

QLabel#status_aapprendre {
    background-color: #E7F0FA;
    color: #2F5C8F;
    border-radius: 12px;
    padding: 0 10px;
    min-height: 22px;
    font-size: 12px;
}

QLabel#status_acquise {
    background-color: #E6F4EE;
    color: #2E7D5A;
    border-radius: 12px;
    padding: 0 10px;
    min-height: 22px;
    font-size: 12px;
}